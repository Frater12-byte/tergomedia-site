{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/industries/finance-legal",
      "destination": "/sectors/finance-legal",
      "statusCode": 308,
      "regex": "^(?!/_next)/industries/finance-legal(?:/)?$"
    },
    {
