      "destination": "/sectors/logistics",
      "statusCode": 308,
      "regex": "^(?!/_next)/industries/logistics(?:/)?$"
    },
    {
      "source": "/industries/:slug",
      "destination": "/sectors/:slug",
      "statusCode": 308,
      "regex": "^(?!/_next)/industries(?:/([^/]+?))(?:/)?$"
    }
  ],
